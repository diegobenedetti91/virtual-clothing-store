generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
}

model CustomerUser {
  id           String         @id @default(cuid())
  email        String         @unique
  password     String
  name         String
  phone        String?
  street       String?
  number       String?
  neighborhood String?
  city         String?
  state        String?
  zipCode      String?
  orders       Order[]
  wishlist     WishlistItem[]
  reviews      ProductReview[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model Category {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  image     String?
  active    Boolean   @default(true)
  products  Product[]
  createdAt DateTime  @default(now())
}

model Product {
  id           String          @id @default(cuid())
  name         String
  description  String?         @db.Text
  price        Float
  comparePrice Float?
  costPrice    Float?
  images       String          @default("[]") @db.Text
  categoryId   String
  category     Category        @relation(fields: [categoryId], references: [id])
  sizes        String          @default("[]") @db.Text
  colors       String          @default("[]") @db.Text
  attributes   String          @default("[]") @db.Text
  stock        Int             @default(0)
  variantStock String          @default("[]") @db.Text
  active       Boolean         @default(true)
  featured     Boolean         @default(false)
  slug         String          @unique
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  orderItems   OrderItem[]
  wishlist     WishlistItem[]
  navItems     NavItem[]
  reviews      ProductReview[]
  waitlist     WaitlistEntry[]
}

model WishlistItem {
  id         String       @id @default(cuid())
  customerId String
  customer   CustomerUser @relation(fields: [customerId], references: [id], onDelete: Cascade)
  productId  String
  product    Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt  DateTime     @default(now())

  @@unique([customerId, productId])
}

model Order {
  id            String        @id @default(cuid())
  orderNumber   String        @unique
  customerName  String
  customerEmail String?
  customerPhone String
  address       String?
  city          String?
  state         String?
  zipCode       String?
  items         OrderItem[]
  subtotal      Float
  total         Float
  status        String        @default("PENDING")
  cancelReason  String?       @db.Text
  trackingCode  String?
  shippingProof String?
  notes         String?       @db.Text
  customerId    String?
  customer      CustomerUser? @relation(fields: [customerId], references: [id])
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float
  size               String?
  color              String?
  selectedAttributes String? @db.Text
}

model NavItem {
  id        String    @id @default(cuid())
  label     String
  href      String
  active    Boolean   @default(true)
  position  Int       @default(0)
  createdAt DateTime  @default(now())
  products  Product[]
}

model CompanySettings {
  id                     String   @id @default(cuid())
  name                   String   @default("Minha Loja")
  logo                   String?
  phone                  String?
  whatsapp               String?
  instagram              String?
  address                String?
  description            String?  @db.Text
  primaryColor           String   @default("#ec4899")
  buttonColor            String   @default("#ec4899")
  menuColor              String   @default("#ec4899")
  bannerImages           String   @default("[]") @db.Text
  checkoutType           String   @default("whatsapp")
  checkoutCollectEmail   Boolean  @default(false)
  checkoutCollectAddress Boolean  @default(false)
  checkoutMessage        String?  @db.Text
  mercadoPagoPublicKey   String?
  mercadoPagoAccessToken String?
  heroBadge              String?
  heroTitle              String?
  heroButtonText         String?
  heroButtonSecondaryText String?
  updatedAt              DateTime @updatedAt
}

model ProductReview {
  id         String        @id @default(cuid())
  productId  String
  product    Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  customerId String?
  customer   CustomerUser? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  authorName String
  rating     Int
  comment    String?       @db.Text
  approved   Boolean       @default(false)
  createdAt  DateTime      @default(now())
}

model WaitlistEntry {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  email     String
  name      String?
  size       String   @default("") @db.VarChar(100)
  color      String   @default("") @db.VarChar(100)
  variantKey String   @default("") @db.VarChar(512)
  notified   Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@unique([productId, email, variantKey])
  @@unique([productId, email, size, color])
}

model VariationTemplate {
  id        String   @id @default(cuid())
  name      String   @unique
  values    String   @default("[]") @db.Text
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AbandonedCart {
  id           String   @id @default(cuid())
  customerId   String?
  email        String   @unique
  cartItems    String   @db.Text
  reminderSent Boolean  @default(false)
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())
}
